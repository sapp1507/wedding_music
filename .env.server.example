COMPOSE_PROJECT_NAME=wedding_music

# Public access
APP_DOMAIN=localhost
APP_HOST=0.0.0.0
APP_PORT=8080
BACKEND_PORT=8000
GUNICORN_WORKERS=3
PUBLIC_URL=http://localhost:8080

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
SONG_REQUEST_SECRET=change-me

# Auto-created admin user. Password is generated by scripts/deploy.sh on first run.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_FORCE_PASSWORD=0

# Internal PostgreSQL for this app only. It is not exposed on the host.
POSTGRES_DB=wedding_music
POSTGRES_USER=wedding_music
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Frontend calls the API through the same nginx container.
VITE_API_BASE_URL=/api
